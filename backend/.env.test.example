APP_NAME=LinkShop API
APP_ENV=test
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
# Optional in platform deploys. When set, PORT overrides APP_PORT.
# PORT=8000
WEB_CONCURRENCY=1
RUN_MIGRATIONS_ON_STARTUP=false
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/linkshop_test
AUTH_SECRET_KEY=test-only-secret-key
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
CORS_ORIGINS=http://localhost:3000
ALERT_PRICE_DROP_THRESHOLD_PERCENTAGE=1.0
INTEGRATION_JSON_FEED_PATH=backend/app/integrations/fixtures/sample_partner_feed.json
LOG_LEVEL=INFO
