APP_NAME=LinkShop API
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
# Optional in platform deploys (Render). When set by platform, PORT overrides APP_PORT.
# PORT=10000
WEB_CONCURRENCY=2
RUN_MIGRATIONS_ON_STARTUP=false
# Prefer managed PostgreSQL in the first external deploy.
# Example: postgresql+psycopg://app_user:strong-password@db-host:5432/linkshop
DATABASE_URL=postgresql+psycopg://app_user:change-me@db:5432/linkshop
AUTH_SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
CORS_ORIGINS=https://app.example.com,https://admin.example.com
ALERT_PRICE_DROP_THRESHOLD_PERCENTAGE=1.0
INTEGRATION_JSON_FEED_PATH=backend/app/integrations/fixtures/sample_partner_feed.json
LOG_LEVEL=INFO
