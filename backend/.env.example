# Local (fora do Docker): localhost
# No Docker Compose o servico backend sobrescreve DATABASE_URL para usar o host "db"
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/linkshop
POSTGRES_DB=linkshop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
APP_NAME=LinkShop API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
# Optional in platform deploys (Render/Heroku style). When set, PORT overrides APP_PORT.
# PORT=8000
WEB_CONCURRENCY=1
RUN_MIGRATIONS_ON_STARTUP=false
AUTH_SECRET_KEY=change-me-in-development
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALERT_PRICE_DROP_THRESHOLD_PERCENTAGE=1.0
INTEGRATION_JSON_FEED_PATH=backend/app/integrations/fixtures/sample_partner_feed.json
LOG_LEVEL=INFO
